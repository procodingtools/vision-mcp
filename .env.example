# Required: API key for authenticating with Ollama Cloud
VISION_API_KEY=your-api-key-here

# Required: Base URL for the Ollama API (without trailing slash)
VISION_API_BASE_URL=https://ollama.com

# Optional: Model to use for vision analysis (default: kimi-k2.6:cloud)
VISION_MODEL=kimi-k2.6:cloud

# Optional: Maximum image file size in megabytes (default: 20)
VISION_MAX_IMAGE_SIZE_MB=20