{
  "name": "vision-mcp",
  "version": "1.0.0",
  "description": "MCP server that bridges non-vision LLMs to a vision LLM via Ollama's native API, enabling image understanding through analyze_image tool calls.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": ["mcp", "vision", "ollama", "image-analysis", "multimodal"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "mime-types": "^3.0.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.0",
    "dotenv": "^16.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}